      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -fd:*)"
    ]
  },
  "hooks": [
    {
      "matcher": "Write|Edit",
      "hooks": [
        {
          "type": "command",
          "command": "if [[ \"$CLAUDE_FILE_PATHS\" =~ \\.py$ ]]; then uv run ruff format \"$CLAUDE_FILE_PATHS\" && uv run ruff check --fix \"$CLAUDE_FILE_PATHS\" 2>/dev/null || true; fi"
        }
      ]
    },
    {
      "matcher": "Edit",
      "hooks": [
        {
          "type": "command",
          "command": "if [[ \"$CLAUDE_FILE_PATHS\" =~ \\.py$ ]]; then uv run mypy \"$CLAUDE_FILE_PATHS\" --ignore-missing-imports 2>/dev/null | tail -5 || true; fi"
        }
      ]
    },
    {
      "matcher": "Write|Edit",
      "hooks": [
        {
          "type": "command",
          "command": "if [[ \"$CLAUDE_FILE_PATHS\" =~ \\.tf$ ]]; then terraform -chdir=$(dirname \"$CLAUDE_FILE_PATHS\") fmt \"$CLAUDE_FILE_PATHS\" 2>/dev/null || true; fi"
        }
      ]
    },
    {
      "matcher": "Write|Edit",
      "hooks": [
        {
          "type": "command",
          "command": "if [[ \"$CLAUDE_FILE_PATHS\" =~ \\.ya?ml$ ]] && [[ \"$CLAUDE_FILE_PATHS\" =~ k8s/ ]]; then kubectl apply --dry-run=client -f \"$CLAUDE_FILE_PATHS\" 2>&1 | tail -3 || true; fi"
        }
      ]
    },
    {
      "matcher": "Write",
      "hooks": [
        {
          "type": "command",
          "command": "if [[ \"$CLAUDE_FILE_PATHS\" =~ Dockerfile ]]; then hadolint \"$CLAUDE_FILE_PATHS\" 2>/dev/null | head -15 || echo 'hadolint not installed'; fi"
        }
      ]
    }
  ],
  "model": "claude-sonnet-4-5",
  "smallFastModel": "claude-haiku-4-5-20251001"
}
